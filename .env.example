# Vorlage — kopiere diese Datei nach ".env" und passe den Pfad an:  cp .env.example .env
#
# Absoluter Pfad zum Spieldaten-Ordner (liegt AUSSERHALB des Repos).
# Darin werden zwei Unterordner genutzt:
#   config/       = Savegames + Servereinstellungen   -> BACKUP
#   serverfiles/  = Server-Installation (~3 GB)        -> regenerierbar, kein Backup
#
# WICHTIG: absoluter Pfad, KEIN ~ verwenden (Docker Compose expandiert ~ nicht).
GAMEDIR=/Users/DEINUSER/Gameserver/Satisfactory

# Reliable-Messaging-Port (TCP). Default 8888. Nur ändern, wenn 8888 auf dem Host
# schon belegt ist (z. B. anderer Container). Wird auf Host UND im Server gesetzt.
# RELIABLE_PORT=7778
